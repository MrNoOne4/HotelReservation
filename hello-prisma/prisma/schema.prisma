generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "mysql"
}



model bedtypes {
  BedTypeId Int    @id @default(autoincrement())
  BedName   String @unique @db.VarChar(50)

  rooms rooms[]
}

model roomtypes {
  RoomTypeId  Int     @id @default(autoincrement())
  TypeName    String  @unique @db.VarChar(50)
  Description String? @db.Text

  rooms rooms[]
}

model rooms {
  RoomId     Int    @id @default(autoincrement())
  RoomNumber String @unique @db.VarChar(20)

  RoomTypeId Int
  BedTypeId  Int

  Floor        Int
  MaxOccupancy Int
  BasePrice    Decimal @db.Decimal(10, 2)
  Description  String? @db.Text

  // Relations
  bedtype  bedtypes  @relation(fields: [BedTypeId], references: [BedTypeId])
  roomtype roomtypes @relation(fields: [RoomTypeId], references: [RoomTypeId])

  images        roomimages[]
  roomamenities roomamenities[]

  reservationrooms reservationrooms[]

}

model roomimages {
  ImageId  Int    @id @default(autoincrement())
  RoomId   Int
  ImageURL String @db.VarChar(1024)

  room rooms @relation(fields: [RoomId], references: [RoomId])
}



model amenities {
  AmenityId   Int    @id @default(autoincrement())
  AmenityName String @db.VarChar(100)

  roomamenities roomamenities[]
}

model roomamenities {
  RoomAmenityId Int @id @default(autoincrement())
  RoomId        Int
  AmenityId     Int

  room    rooms     @relation(fields: [RoomId], references: [RoomId])
  amenity amenities @relation(fields: [AmenityId], references: [AmenityId])

  @@index([RoomId])
  @@index([AmenityId])
}



model reservations {
  ReservationId Int                  @id @default(autoincrement())
  UserId        Int
  GuestFirstName String @db.VarChar(100)
  GuestLastName String @db.VarChar(100)
  GuestPhone String @db.VarChar(100)
  GuestAddress String @db.VarChar(100)
  CheckInDate   DateTime             @db.Date
  CheckOutDate  DateTime             @db.Date
  Status        reservations_Status? @default(Pending)
  CreatedAt     DateTime?            @default(now()) @db.Timestamp(0)

  reservationrooms reservationrooms[]
  @@index([UserId])
}

model reservationrooms {
  ReservationRoomId Int     @id @default(autoincrement())
  ReservationId     Int
  RoomId            Int
  PriceAtBooking    Decimal @db.Decimal(10, 2)

  reservation reservations @relation(fields: [ReservationId], references: [ReservationId])
  room        rooms         @relation(fields: [RoomId], references: [RoomId])

  @@index([ReservationId])
  @@index([RoomId])
}


model payments {
  PaymentId     Int                     @id @default(autoincrement())
  ReservationId Int
  Amount        Decimal                 @db.Decimal(10, 2)
  PaymentMethod payments_PaymentMethod
  PaymentStatus payments_PaymentStatus? @default(Pending)
  PaymentDate   DateTime?               @default(now()) @db.Timestamp(0)

  @@index([ReservationId])
}


model roomblocks {
  BlockId     Int                @id @default(autoincrement())
  RoomId      Int
  BlockedFrom DateTime           @db.Date
  BlockedTo   DateTime           @db.Date
  Reason      roomblocks_Reason? @default(Reserved)

  @@index([RoomId])
}


model users {
  UserId       Int       @id @default(autoincrement())
  FullName     String    @db.VarChar(255)
  Email        String    @unique @db.VarChar(255)
  PasswordHash String    @db.VarChar(255)
  IsVerified   Boolean?  @default(false)
  CreatedAt    DateTime? @default(now()) @db.Timestamp(0)
}

model userauthproviders {
  AuthId         Int                        @id @default(autoincrement())
  UserId         Int
  Provider       userauthproviders_Provider
  ProviderUserId String?                    @db.VarChar(255)
  CreatedAt      DateTime?                  @default(now()) @db.Timestamp(0)

  @@index([UserId])
}


enum userauthproviders_Provider {
  google
  facebook
}

enum payments_PaymentMethod {
  CreditCard
  DebitCard
  PayPal
  Cash
}

enum payments_PaymentStatus {
  Pending
  Completed
  Failed
}

enum reservations_Status {
  Pending
  Confirmed
  Cancelled
  Completed
}

enum roomblocks_Reason {
  Maintenance
  Reserved
  Cleaning
}
