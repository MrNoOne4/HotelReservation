generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}


model users {
  UserId       Int       @id @default(autoincrement())
  FullName     String    @db.VarChar(255)
  Email        String    @unique @db.VarChar(255)
  PasswordHash String    @db.VarChar(255)
  Role         String    @default("user")
  IsVerified   Boolean?  @default(false)
  CreatedAt    DateTime? @default(now()) @db.Timestamp(0)

  reservations     reservations[] @relation("UserReservations")
  checkedInBy      reservations[] @relation("CheckedInBy")
  checkedOutBy     reservations[] @relation("CheckedOutBy")

  verifiedPayments payments[]
  userauthproviders userauthproviders[]
}


model userauthproviders {
  AuthId         Int                        @id @default(autoincrement())
  UserId         Int
  Provider       userauthproviders_Provider
  ProviderUserId String?                    @db.VarChar(255)
  CreatedAt      DateTime?                  @default(now()) @db.Timestamp(0)

  user users @relation(fields: [UserId], references: [UserId])

  @@index([UserId])
}


model roomtypes {
  RoomTypeId  Int     @id @default(autoincrement())
  TypeName    String  @unique @db.VarChar(50)
  Description String? @db.Text

  rooms rooms[]
}

model bedtypes {
  BedTypeId Int    @id @default(autoincrement())
  BedName   String @unique @db.VarChar(50)

  rooms rooms[]
}

model rooms {
  RoomId       Int     @id @default(autoincrement())
  RoomNumber   String  @unique @db.VarChar(20)
  RoomTypeId   Int
  BedTypeId    Int
  Floor        Int
  MaxOccupancy Int
  BasePrice    Decimal @db.Decimal(10, 2)
  Description  String? @db.Text

  bedtype  bedtypes  @relation(fields: [BedTypeId], references: [BedTypeId])
  roomtype roomtypes @relation(fields: [RoomTypeId], references: [RoomTypeId])

  images           roomimages[]
  roomamenities    roomamenities[]

  reservationrooms reservationrooms[]
}

model roomimages {
  ImageId  Int    @id @default(autoincrement())
  RoomId   Int
  ImageURL String @db.Text

  room rooms @relation(fields: [RoomId], references: [RoomId], onDelete: Cascade)
}

model amenities {
  AmenityId   Int    @id @default(autoincrement())
  AmenityName String @db.VarChar(100)

  roomamenities roomamenities[]
}

model roomamenities {
  RoomAmenityId Int @id @default(autoincrement())
  RoomId        Int
  AmenityId     Int

  room    rooms     @relation(fields: [RoomId], references: [RoomId], onDelete: Cascade)
  amenity amenities @relation(fields: [AmenityId], references: [AmenityId])

  @@index([RoomId])
  @@index([AmenityId])
}

model roomblocks {
  BlockId     Int                @id @default(autoincrement())
  RoomId      Int
  BlockedFrom DateTime           @db.Date
  BlockedTo   DateTime           @db.Date
  Reason      roomblocks_Reason? @default(Reserved)

  @@index([RoomId])
}


model reservations {
  ReservationId  Int     @id @default(autoincrement())
  UserId         Int?  

  GuestFirstName String? @db.VarChar(255)
  GuestLastName  String? @db.VarChar(255)
  GuestPhone     String? @db.VarChar(255)
  GuestAddress   String? @db.VarChar(255)

  CheckInDate    DateTime  @db.Date
  CheckOutDate   DateTime  @db.Date

  ActualCheckIn  DateTime? @db.Timestamp(0)
  ActualCheckOut DateTime? @db.Timestamp(0)

  CheckedInBy    Int?
  CheckedOutBy   Int?

  Status         reservations_Status? @default(Pending)

  CancelReason   String?   @db.VarChar(255)
  CancelledAt    DateTime? @db.Timestamp(0)

  CreatedAt      DateTime? @default(now()) @db.Timestamp(0)

  // Relations
  user        users? @relation("UserReservations", fields: [UserId], references: [UserId], onDelete: SetNull)
  checkedIn   users? @relation("CheckedInBy",      fields: [CheckedInBy],  references: [UserId], onDelete: SetNull)
  checkedOut  users? @relation("CheckedOutBy",      fields: [CheckedOutBy], references: [UserId], onDelete: SetNull)

  reservationrooms reservationrooms[]
  payments         payments[]

  @@index([UserId])
  @@index([CheckedInBy])
  @@index([CheckedOutBy])
}

model reservationrooms {
  ReservationRoomId Int     @id @default(autoincrement())
  ReservationId     Int
  RoomId            Int? 
  PriceAtBooking    Decimal @db.Decimal(10, 2)
  reservation reservations @relation(fields: [ReservationId], references: [ReservationId])
  room rooms? @relation(fields: [RoomId], references: [RoomId], onDelete: SetNull)

  @@index([ReservationId])
  @@index([RoomId])
}


model payments {
  PaymentId     Int     @id @default(autoincrement())
  ReservationId Int
  Amount        Decimal @db.Decimal(10, 2)
  PaymentMethod payments_PaymentMethod
  PaymentStatus payments_PaymentStatus? @default(Pending)
  ReferenceCode String?   @db.VarChar(50)
  VerifiedBy    Int?
  VerifiedAt    DateTime? @db.Timestamp(0)
  PaidAt        DateTime? @db.Timestamp(0)
  PaymentDate   DateTime? @default(now()) @db.Timestamp(0)
  reservation reservations @relation(fields: [ReservationId], references: [ReservationId])
  verifiedBy  users? @relation(fields: [VerifiedBy], references: [UserId], onDelete: SetNull)
  @@index([ReservationId])
  @@index([VerifiedBy])
}

enum userauthproviders_Provider {
  google
  facebook
}

enum payments_PaymentMethod {
  Cash
  GCash
  CreditCard
  DebitCard
}

enum payments_PaymentStatus {
  Pending
  AwaitingVerification
  Completed
  Failed
  Refunded
}

enum reservations_Status {
  Pending
  Confirmed
  Cancelled
  Completed
  NoShow
}

enum roomblocks_Reason {
  Maintenance
  Reserved
  Cleaning
}
